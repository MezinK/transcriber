# Database
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/transcriptions

# Upload settings
UPLOAD_DIR=/uploads
MAX_UPLOAD_BYTES=524288000  # 500 MB

# DB connection pool (tune per service)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30

# Worker settings
TRANSCRIPTION_ENGINE=faster-whisper
WHISPER_MODEL=base
